---
---

<!-- Header / Navigation -->
<header class="fixed top-0 left-0 right-0 z-50 bg-white/90 backdrop-blur-sm border-b border-gray-100">
	<nav class="mx-auto flex max-w-6xl items-center justify-between px-6 py-4">
		<a href="/" class="flex items-center gap-3">
			<img src="/logo.svg" alt="Everyday Studio" class="h-8 w-8" />
			<span class="text-lg font-bold text-navy">Everyday Studio</span>
		</a>
		<div class="hidden items-center gap-8 md:flex">
			<a href="#about" class="text-sm text-gray-600 transition-colors hover:text-teal">소개</a>
			<a href="#services" class="text-sm text-gray-600 transition-colors hover:text-teal">서비스</a>
			<a href="#contact" class="text-sm text-gray-600 transition-colors hover:text-teal">문의</a>
		</div>
	</nav>
</header>

<!-- Hero Section -->
<section class="flex min-h-screen flex-col items-center justify-center px-6 pt-20 text-center">
	<div class="mb-8">
		<img src="/logo.svg" alt="Everyday Studio Logo" class="mx-auto h-32 w-32 md:h-40 md:w-40" />
	</div>
	<h1 class="mb-4 text-4xl font-bold text-navy md:text-5xl lg:text-6xl">
		매일의 아이디어를 현실로 만듭니다
	</h1>
	<p class="mb-8 max-w-2xl text-lg text-gray-500 md:text-xl">
		Everyday Studio는 다양한 웹 서비스를 만들고 운영하는 크리에이티브 스튜디오입니다.
	</p>
	<div class="flex flex-wrap items-center justify-center gap-3">
		<span class="rounded-full bg-teal/10 px-4 py-2 text-sm font-medium text-teal">ollm.everydaystudio.xyz</span>
		<span class="rounded-full bg-coral/10 px-4 py-2 text-sm font-medium text-coral">????.everydaystudio.xyz</span>
		<span class="rounded-full bg-mustard/10 px-4 py-2 text-sm font-medium text-mustard">????.everydaystudio.xyz</span>
	</div>
</section>

<!-- About Section -->
<section id="about" class="bg-gray-50 px-6 py-24">
	<div class="mx-auto max-w-4xl text-center">
		<h2 class="mb-4 text-3xl font-bold text-navy md:text-4xl">About Us</h2>
		<p class="mb-12 text-lg leading-loose text-gray-600">
			우리는 일상 속 작은 아이디어에서 출발하여,<br />
			사람들에게 가치를 전달하는 서비스를 만듭니다.<br />
			기술과 디자인의 균형을 추구하며,<br />
			매일 조금씩 더 나은 경험을 만들어갑니다.
		</p>
		<div class="grid gap-8 md:grid-cols-3">
			<div class="rounded-2xl bg-white px-6 py-8 shadow-sm border border-gray-100 transition-all hover:shadow-md">
				<div class="mb-5 inline-flex h-14 w-14 items-center justify-center rounded-xl bg-teal/10 text-2xl">🎨</div>
				<h3 class="mb-3 text-lg font-bold text-navy">디자인</h3>
				<p class="text-sm leading-relaxed text-gray-500">사용자 중심의 직관적이고<br />아름다운 인터페이스</p>
			</div>
			<div class="rounded-2xl bg-white px-6 py-8 shadow-sm border border-gray-100 transition-all hover:shadow-md">
				<div class="mb-5 inline-flex h-14 w-14 items-center justify-center rounded-xl bg-coral/10 text-2xl">⚡</div>
				<h3 class="mb-3 text-lg font-bold text-navy">기술</h3>
				<p class="text-sm leading-relaxed text-gray-500">최신 웹 기술로 빠르고<br />안정적인 서비스 구현</p>
			</div>
			<div class="rounded-2xl bg-white px-6 py-8 shadow-sm border border-gray-100 transition-all hover:shadow-md">
				<div class="mb-5 inline-flex h-14 w-14 items-center justify-center rounded-xl bg-mustard/10 text-2xl">🚀</div>
				<h3 class="mb-3 text-lg font-bold text-navy">성장</h3>
				<p class="text-sm leading-relaxed text-gray-500">지속적인 개선과 발전을 통한<br />가치 창출</p>
			</div>
		</div>
	</div>
</section>

<!-- Services Section -->
<section id="services" class="px-6 py-24">
	<div class="mx-auto max-w-4xl">
		<h2 class="mb-12 text-center text-3xl font-bold text-navy md:text-4xl">Services</h2>
		<div class="grid gap-6 md:grid-cols-3">
			<!-- OLLM - Live -->
			<a
				href="https://ollm.everydaystudio.xyz"
				target="_blank"
				rel="noopener noreferrer"
				class="group relative overflow-hidden rounded-2xl border border-gray-200 p-6 transition-all hover:border-teal hover:shadow-lg"
			>
				<div class="mb-3 flex items-center gap-2">
					<span class="inline-block h-2 w-2 rounded-full bg-teal animate-pulse"></span>
					<span class="text-xs font-medium text-teal">Live</span>
				</div>
				<h3 class="mb-2 text-xl font-bold text-navy">OLLM</h3>
				<p class="text-sm text-gray-500">ollm.everydaystudio.xyz</p>
			</a>

			<!-- Coming Soon 1 -->
			<div class="relative overflow-hidden rounded-2xl border border-gray-100 bg-gray-50 p-6">
				<div class="mb-3 flex items-center gap-2">
					<span class="inline-block h-2 w-2 rounded-full bg-mustard"></span>
					<span class="text-xs font-medium text-mustard">Coming Soon</span>
				</div>
				<h3 class="mb-2 text-xl font-bold text-gray-300">???</h3>
				<p class="text-sm text-gray-400">준비 중입니다</p>
			</div>

			<!-- Coming Soon 2 -->
			<div class="relative overflow-hidden rounded-2xl border border-gray-100 bg-gray-50 p-6">
				<div class="mb-3 flex items-center gap-2">
					<span class="inline-block h-2 w-2 rounded-full bg-mustard"></span>
					<span class="text-xs font-medium text-mustard">Coming Soon</span>
				</div>
				<h3 class="mb-2 text-xl font-bold text-gray-300">???</h3>
				<p class="text-sm text-gray-400">준비 중입니다</p>
			</div>
		</div>
	</div>
</section>

<!-- Contact Section -->
<section id="contact" class="bg-navy px-6 py-24 text-white">
	<div class="mx-auto max-w-4xl text-center">
		<h2 class="mb-8 text-3xl font-bold md:text-4xl">Contact</h2>
		<a
			href="mailto:everydaystudio365@gmail.com"
			class="inline-flex items-center gap-2 rounded-full bg-teal px-8 py-3 font-medium text-white transition-colors hover:bg-teal-dark"
		>
			<svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
				<path d="M2.003 5.884L10 9.882l7.997-3.998A2 2 0 0016 4H4a2 2 0 00-1.997 1.884z" />
				<path d="M18 8.118l-8 4-8-4V14a2 2 0 002 2h12a2 2 0 002-2V8.118z" />
			</svg>
			everydaystudio365@gmail.com
		</a>
	</div>
</section>

<!-- Footer -->
<footer class="border-t border-gray-100 px-6 py-12">
	<div class="mx-auto max-w-6xl">
		<div class="flex flex-col gap-10 md:flex-row md:justify-between">
			<!-- Logo + Social -->
			<div class="flex flex-col gap-5">
				<div class="flex items-center gap-3">
					<img src="/logo.svg" alt="Everyday Studio" class="h-7 w-7" />
					<span class="text-base font-bold text-navy">Everyday Studio</span>
				</div>
				<div class="flex items-center gap-4">
					<!-- Instagram -->
					<a href="https://www.instagram.com/everydaystudio365/" target="_blank" rel="noopener noreferrer" class="text-gray-400 transition-colors hover:text-navy">
						<svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
					</a>
					<!-- YouTube -->
				<a href="https://youtube.com/@everydaystudio-d5q?si=t-c5yGMIFv1S68XG" target="_blank" rel="noopener noreferrer" class="text-gray-400 transition-colors hover:text-navy">
						<svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24"><path d="M23.498 6.186a3.016 3.016 0 00-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 00.502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 002.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 002.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
					</a>
					<!-- GitHub -->
					<a href="https://github.com/everyday-studio" target="_blank" rel="noopener noreferrer" class="text-gray-400 transition-colors hover:text-navy">
						<svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/></svg>
					</a>
				</div>
			</div>

		<!-- QR Code + Links -->
		<div class="flex flex-col gap-10 md:flex-row md:gap-16 md:items-start">
			<!-- Instagram QR Code -->
			<div class="flex flex-col items-center gap-2">
				<a href="https://www.instagram.com/everydaystudio365/" target="_blank" rel="noopener noreferrer" class="rounded-lg border border-gray-100 bg-white p-3 transition-all hover:border-teal hover:shadow-md">
					<img src="/instagram-qr.svg" alt="Instagram QR Code" class="h-28 w-28" />
				</a>
				<span class="text-xs font-semibold text-gray-500">Follow Us</span>
			</div>

			<!-- Links -->
			<div class="flex gap-16">
				<div>
					<h4 class="mb-3 text-sm font-semibold text-navy">서비스</h4>
					<ul class="flex flex-col gap-2">
						<li><a href="https://ollm.everydaystudio.xyz" target="_blank" rel="noopener noreferrer" class="text-sm text-gray-400 transition-colors hover:text-teal">OLLM</a></li>
					</ul>
				</div>
				<div>
					<h4 class="mb-3 text-sm font-semibold text-navy">소개</h4>
					<ul class="flex flex-col gap-2">
						<li><a href="#about" class="text-sm text-gray-400 transition-colors hover:text-teal">팀 소개</a></li>
						<li><a href="https://github.com/everyday-studio" target="_blank" rel="noopener noreferrer" class="text-sm text-gray-400 transition-colors hover:text-teal">GitHub</a></li>
					</ul>
				</div>
			</div>
		</div>

		<!-- Copyright -->
		<div class="mt-10 border-t border-gray-100 pt-6">
			<p class="text-sm text-gray-400">&copy; 2025 Everyday Studio. All rights reserved.</p>
		</div>
	</div>
</footer>
